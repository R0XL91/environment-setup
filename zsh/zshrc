## Zsh configuration (improved and idempotent)

# Path to Oh My Zsh installation (default)
export ZSH="${ZSH:-$HOME/.oh-my-zsh}"

# Theme: Powerlevel10k (keep value if set externally)
ZSH_THEME="${ZSH_THEME:-powerlevel10k/powerlevel10k}"

# Plugins
plugins=(
  git
  zsh-autosuggestions
  zsh-syntax-highlighting
)

# Source Oh My Zsh if present
if [ -s "$ZSH/oh-my-zsh.sh" ]; then
  # shellcheck disable=SC1090
  source "$ZSH/oh-my-zsh.sh"
fi

# Locale defaults (only set if not already defined)
export LANG="${LANG:-es_ES.UTF-8}"
export LC_ALL="${LC_ALL:-$LANG}"

# History configuration (use defaults only if not set)
export HISTFILE="${HISTFILE:-$HOME/.zsh_history}"
export HISTSIZE="${HISTSIZE:-10000}"
export SAVEHIST="${SAVEHIST:-10000}"

setopt APPEND_HISTORY
setopt SHARE_HISTORY
setopt HIST_REDUCE_BLANKS
setopt HIST_IGNORE_SPACE
setopt HIST_EXPIRE_DUPS_FIRST

# Default editor
export EDITOR="${EDITOR:-nano}"

# Load aliases if present
for _f in "$HOME/.aliases" "$HOME/.aliases.local"; do
  if [ -r "$_f" ] && [ -f "$_f" ]; then
    # shellcheck disable=SC1090
    source "$_f"
  fi
done
unset _f

# If using Powerlevel10k theme, let it handle the prompt. Otherwise set a simple prompt.
if [[ "$ZSH_THEME" != "powerlevel10k/powerlevel10k" ]]; then
  autoload -U promptinit && promptinit
  PROMPT='%F{cyan}%n@%m%f:%F{green}%~%f %# '
fi

# Helper to prepend to PATH without duplicating entries
path_prepend() {
  case ":$PATH:" in
    *":$1:"*) :;;
    *) PATH="$1:$PATH";;
  esac
}
path_prepend "$HOME/bin"
path_prepend "$HOME/.local/bin"
path_prepend "/usr/local/bin"
export PATH

# Enable autojump if available (common install locations)
if [ -f /usr/share/autojump/autojump.zsh ]; then
  # shellcheck disable=SC1090
  source /usr/share/autojump/autojump.zsh
elif [ -f /etc/profile.d/autojump.sh ]; then
  # shellcheck disable=SC1090
  source /etc/profile.d/autojump.sh
fi

# Powerlevel10k instant prompt (if user provided a custom p10k file)
P10K_SRC="${ZSH_CUSTOM:-$HOME/.oh-my-zsh/custom}/themes/powerlevel10k/.p10k.zsh"
if [ -f "$P10K_SRC" ]; then
  # shellcheck disable=SC1090
  source "$P10K_SRC"
fi

# zsh-autosuggestions config: only set if plugin appears installed
if [ -d "${ZSH_CUSTOM:-$HOME/.oh-my-zsh/custom}/plugins/zsh-autosuggestions" ]; then
  export ZSH_AUTOSUGGEST_HIGHLIGHT_STYLE="fg=10"
fi
